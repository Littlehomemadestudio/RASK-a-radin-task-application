<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ===== Permissions ===== -->
    <!-- Foreground service for the live timer -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_STOPWATCH" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Vibrator for milestone haptics -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Receive boot completed to re-arm reminder work -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Use exact alarms for in-app reminders only -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Biometrics -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Microphone for voice input on activity titles -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Hardware feature declarations — make app discoverable but not exclusive -->
    <uses-feature android:name="android.hardware.fingerprint" android:required="false" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <application
        android:name=".RaskApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Rask"
        tools:targetApi="34">

        <!-- Splash — the launcher activity -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Rask.Splash"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding (3 screens) -->
        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.Rask" />

        <!-- App-lock gate (PIN / biometrics) -->
        <activity
            android:name=".ui.settings.LockActivity"
            android:exported="false"
            android:theme="@style/Theme.Rask" />

        <!-- Main bottom-nav host -->
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.Rask"
            android:launchMode="singleTop" />

        <!-- Quick-log shortcut activity (FAB launcher variant for widget) -->
        <activity
            android:name=".ui.home.QuickLogActivity"
            android:exported="false"
            android:theme="@style/Theme.Rask.Translucent" />

        <!-- Foreground timer service -->
        <service
            android:name=".service.TimerService"
            android:exported="false"
            android:foregroundServiceType="stopwatch|dataSync" />

        <!-- Boot receiver — reschedule reminder work after reboot -->
        <receiver
            android:name=".utils.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Quick-tile receiver (start/stop timer from quick settings) -->
        <receiver
            android:name=".widget.TimerTileReceiver"
            android:exported="false" />

        <!-- Home-screen widget -->
        <receiver
            android:name=".widget.RaskWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/rask_widget_info" />
        </receiver>

        <!-- FileProvider for encrypted backup export / share -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Disable WorkManager's default initializer — we initialise in RaskApplication -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>
</manifest>

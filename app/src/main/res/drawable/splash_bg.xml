<?xml version="1.0" encoding="utf-8"?>
<!-- Splash background: pure black with a faint gold radial glow center -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <color android:color="@color/rask_black" />
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="600"
                android:startColor="#22D4AF37"
                android:endColor="#00000000" />
            <size android:width="600dp" android:height="600dp" />
        </shape>
    </item>
</layer-list>

<?xml version="1.0" encoding="utf-8"?>
<!--
    MainActivity host — bottom navigation + fragment host + FAB.
    FAB is centered above the bottom bar (raised). It launches quick-log.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/android/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rask_black"
    android:fitsSystemWindows="true">

    <!-- Fragment host -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph" />

    <!-- Bottom navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:menu="@menu/bottom_nav_menu" />

    <!-- Centered FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabQuickLog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="28dp"
        android:contentDescription="@string/cd_quick_log"
        android:src="@drawable/ic_add"
        app:tint="@color/rask_black"
        app:backgroundTint="@color/rask_gold"
        app:elevation="8dp"
        app:borderWidth="0dp"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Rask.FAB" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
    Onboarding — 3 vertical screens.
    Each slide: large gold illustration (top), headline, body, gold CTA (bottom).
    Viewed on dark background, generous negative space.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/android/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rask_black"
    android:padding="24dp">

    <!-- Skip -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/btnSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/onboarding_skip"
        android:textColor="@color/rask_gray"
        android:padding="12dp"
        android:fontFamily="sans-serif-light"
        android:textSize="14sp"
        android:letterSpacing="0.06"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Illustration area -->
    <FrameLayout
        android:id="@+id/illustrationFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnSkip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/headline"
        app:layout_constraintHeight_percent="0.42">

        <ImageView
            android:id="@+id/illustration"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name"
            tools:src="@drawable/ic_splash_logo"
            xmlns:tools="http://schemas.android.com/tools" />
    </FrameLayout>

    <!-- Headline -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/headline"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Rask.Headline"
        android:textSize="26sp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        app:layout_constraintBottom_toTopOf="@id/body"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.86" />

    <!-- Body -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Rask.Body"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="14dp"
        android:lineSpacingExtra="3dp"
        app:layout_constraintBottom_toTopOf="@id/pagerIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.86" />

    <!-- Pager dots -->
    <LinearLayout
        android:id="@+id/pagerIndicator"
        android:layout_width="wrap_content"
        android:layout_height="8dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/btnContinue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View android:id="@+id/dot0"
            android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/onboarding_dot_active"
            android:layout_marginHorizontal="5dp" />
        <View android:id="@+id/dot1"
            android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/onboarding_dot_inactive"
            android:layout_marginHorizontal="5dp" />
        <View android:id="@+id/dot2"
            android:layout_width="8dp" android:layout_height="8dp"
            android:background="@drawable/onboarding_dot_inactive"
            android:layout_marginHorizontal="5dp" />
    </LinearLayout>

    <!-- CTA -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/onboarding_next"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.86" />

</androidx.constraintlayout.widget.ConstraintLayout>

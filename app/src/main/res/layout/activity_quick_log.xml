<?xml version="1.0" encoding="utf-8"?>
<!--
    QuickLog bottom-sheet-like layout.
    Used as a full-screen translucent activity with a centered card.
    Provides: title (with mic), duration HH:MM, category picker, notes,
    Save + Start-timer buttons.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/android/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/rask_scrim">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card"
            style="@style/Widget.Rask.CardView.Gold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.92">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Header row: title + close -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/quick_log"
                        android:textAppearance="@style/TextAppearance.Rask.GoldLabel"
                        android:textSize="13sp" />

                    <ImageButton
                        android:id="@+id/btnClose"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_close"
                        android:contentDescription="@string/close"
                        app:tint="@color/rask_gray_light" />
                </LinearLayout>

                <!-- Title input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/titleLayout"
                    style="@style/Widget.Rask.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="@string/quick_log_title_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/titleInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapSentences"
                        android:maxLength="120"
                        android:textColor="@color/rask_cream"
                        android:imeOptions="actionNext" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Voice button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVoice"
                    style="@style/Widget.Rask.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="@string/quick_log_voice_hint"
                    app:icon="@drawable/ic_mic"
                    app:iconTint="@color/rask_gold" />

                <!-- Duration row -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/quick_log_duration"
                    android:textAppearance="@style/TextAppearance.Rask.GoldLabel" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Rask.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/quick_log_hours_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/hoursInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="3"
                            android:textColor="@color/rask_cream"
                            android:gravity="center" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textColor="@color/rask_gray"
                        android:textSize="22sp"
                        android:layout_marginHorizontal="12dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Rask.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/quick_log_minutes_hint">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/minutesInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:maxLength="2"
                            android:textColor="@color/rask_cream"
                            android:gravity="center" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Category dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Rask.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="@string/quick_log_category">

                    <AutoCompleteTextView
                        android:id="@+id/categoryInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:popupBackground="@color/rask_card"
                        android:textColor="@color/rask_cream" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Notes -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Rask.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/quick_log_notes">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/notesInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="2"
                        android:maxLength="400"
                        android:textColor="@color/rask_cream" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Templates chips -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/templatesLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/quick_log_templates"
                    android:textAppearance="@style/TextAppearance.Rask.GoldLabel" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/templatesList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:overScrollMode="never" />

                <!-- Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartTimer"
                        style="@style/Widget.Rask.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/quick_log_start_timer"
                        app:icon="@drawable/ic_play"
                        app:iconTint="@color/rask_gold" />

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="wrap_content" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSave"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/quick_log_save" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<!--
    Home screen — scrollable column with:
      - Today hero card (total time + gold ring)
      - Weekly progress ring(s) for active goals
      - Timer panel (if running) — pause/stop
      - Recent activities list
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/android/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rask_black">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name"
            app:titleTextAppearance="@style/TextAppearance.Rask.Headline"
            app:titleTextColor="@color/rask_gold"
            android:background="@android:color/transparent" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- ===== Timer panel (only visible when timer running) ===== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/timerPanel"
                style="@style/Widget.Rask.CardView.Gold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/timerTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Rask.GoldLabel"
                        android:textSize="12sp" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/timerDisplay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif-light"
                        android:textColor="@color/rask_gold"
                        android:textSize="42sp"
                        android:letterSpacing="-0.04"
                        tools:text="00:42:13"
                        xmlns:tools="http://schemas.android.com/tools" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTimerPause"
                            style="@style/Widget.Rask.Button.Outlined"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/timer_pause"
                            app:icon="@drawable/ic_pause"
                            app:iconTint="@color/rask_gold" />

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="wrap_content" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTimerStop"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/timer_stop"
                            app:icon="@drawable/ic_stop"
                            app:iconTint="@color/rask_black" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Today hero ===== -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Rask.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Ring -->
                    <com.rask.app.ui.common.ProgressRingView
                        android:id="@+id/todayRing"
                        android:layout_width="96dp"
                        android:layout_height="96dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="20dp">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_today_total"
                            android:textAppearance="@style/TextAppearance.Rask.GoldLabel" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/todayTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif-light"
                            android:textColor="@color/rask_cream"
                            android:textSize="34sp"
                            android:letterSpacing="-0.03"
                            tools:text="2h 45m"
                            xmlns:tools="http://schemas.android.com/tools" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/todaySubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:textAppearance="@style/TextAppearance.Rask.Caption"
                            tools:text="of 4h daily goal"
                            xmlns:tools="http://schemas.android.com/tools" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ===== Weekly progress rings ===== -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginStart="6dp"
                android:text="@string/home_goal_progress"
                android:textAppearance="@style/TextAppearance.Rask.GoldLabel" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/goalsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:overScrollMode="never"
                android:nestedScrollingEnabled="false" />

            <!-- ===== Recent ===== -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:layout_marginStart="6dp"
                android:text="@string/home_recent"
                android:textAppearance="@style/TextAppearance.Rask.GoldLabel" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recentList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:overScrollMode="never"
                android:nestedScrollingEnabled="false" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="40dp"
                android:gravity="center"
                android:text="@string/home_no_activities"
                android:textAppearance="@style/TextAppearance.Rask.Body"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-android/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rask_black">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/settings_title"
            app:titleTextAppearance="@style/TextAppearance.Rask.Headline"
            app:titleTextColor="@color/rask_gold"
            android:background="@android:color/transparent" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- Appearance section -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="6dp"
                android:text="@string/settings_appearance"
                android:textAppearance="@style/TextAppearance.Rask.GoldLabel" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Rask.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/swAmoled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/settings_theme_amoled"
                        android:textColor="@color/rask_cream"
                        android:fontFamily="sans-serif-light" />

                    <View android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="10dp"
                        android:background="@color/rask_card_border" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_language"
                            android:textColor="@color/rask_cream"
                            android:fontFamily="sans-serif-light" />
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.Rask.TextInputLayout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:minWidth="160dp">
                            <AutoCompleteTextView
                                android:id="@+id/languageInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:popupBackground="@color/rask_card"
                                android:textColor="@color/rask_cream" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Privacy section -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="6dp"
                android:text="@string/settings_privacy"
                android:textAppearance="@style/TextAppearance.Rask.GoldLabel" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Rask.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/rowAppLock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="4dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/settings_app_lock"
                                android:textColor="@color/rask_cream"
                                android:fontFamily="sans-serif-light" />
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/appLockSummary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Rask.Caption"
                                android:textSize="11sp" />
                        </LinearLayout>
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/swAppLock"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <View android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="10dp"
                        android:background="@color/rask_card_border" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/settings_biometrics"
                            android:textColor="@color/rask_cream"
                            android:fontFamily="sans-serif-light" />
                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:id="@+id/swBiometrics"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Reminders section -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="6dp"
                android:text="@string/settings_reminders"
                android:textAppearance="@style/TextAppearance.Rask.GoldLabel" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Rask.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_reminders_summary"
                        android:textColor="@color/rask_cream"
                        android:fontFamily="sans-serif-light" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/swReminders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Data section -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="6dp"
                android:text="@string/settings_data"
                android:textAppearance="@style/TextAppearance.Rask.GoldLabel" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Rask.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBackup"
                        style="@style/Widget.Rask.Button.Text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="start|center_vertical"
                        android:text="@string/settings_backup"
                        app:icon="@drawable/ic_backup"
                        app:iconTint="@color/rask_gold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRestore"
                        style="@style/Widget.Rask.Button.Text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="start|center_vertical"
                        android:text="@string/settings_restore"
                        app:icon="@drawable/ic_history"
                        app:iconTint="@color/rask_gold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExportCsv"
                        style="@style/Widget.Rask.Button.Text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="start|center_vertical"
                        android:text="@string/settings_export_csv"
                        app:icon="@drawable/ic_history"
                        app:iconTint="@color/rask_gold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClear"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="start|center_vertical"
                        android:text="@string/settings_clear"
                        android:textColor="@color/rask_error"
                        app:icon="@drawable/ic_delete"
                        app:iconTint="@color/rask_error"
                        style="@style/Widget.Rask.Button.Text" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- About -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="6dp"
                android:text="@string/settings_about"
                android:textAppearance="@style/TextAppearance.Rask.GoldLabel" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Rask.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="40dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textColor="@color/rask_gold"
                        android:fontFamily="sans-serif-light"
                        android:textSize="20sp" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/versionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="@style/TextAppearance.Rask.Caption"
                        tools:text="Version 1.0.0"
                        xmlns:tools="http://schemas.android.com/tools" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/about_description"
                        android:textAppearance="@style/TextAppearance.Rask.Body"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
